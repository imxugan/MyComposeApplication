# ============================================================================
# 6. 其他临时文件与日志
# ============================================================================

*.log                 # 日志文件
*.hprof               # Android Studio 内存快照
captures/             # Android Studio 截图保存目录
.navigation/          # 导航编辑器临时文件
output-metadata.json  # 构建元数据
vcs.xml               # IntelliJ 版本控制配置（已被 .idea/ 覆盖，显式列出无妨）

# ============================================================================
# 7. KMP 跨平台项目专用：iOS 相关文件
#    （若项目不含 iOS 目标，此部分可删除）
# ============================================================================

**/iosApp/Pods/                           # CocoaPods 依赖目录（推荐忽略）
**/iosApp/*.xcworkspace                   # Xcode workspace 文件
**/iosApp/*.xcodeproj/project.xcworkspace/ # workspace 缓存
**/iosApp/*.xcodeproj/xcuserdata/         # 用户数据（断点、窗口布局）
**/iosApp/*.xcodeproj/project.pbxproj     # Xcode 工程文件（极易冲突）
**/iosApp/iosApp.xcworkspace/             # 应用级别的 workspace
**/iosApp/*.xcuserstate                   # 用户状态文件
**/iosApp/UserInterfaceState.xcuserstate  # UI 状态（如打开的文件）
