# ============================================================================

# macOS 系统文件
.DS_Store
.AppleDouble
.LSOverride

# Windows 系统文件
Thumbs.db
ehthumbs.db
desktop.ini

# 常见编辑器（Vim、Emacs、Sublime等）自动生成的备份文件
*.swp
*.swo
*~

# ============================================================================
# 2. 构建输出与缓存（GitHub 官方 Android 模板完整版）
#    （自动生成的文件，提交会导致冲突和仓库膨胀）
# ============================================================================

# Android 构建产物
*.apk          # 安装包
*.aar          # Android Archive（模块输出）
*.ap_          # 未签名的中间包
*.aab          # Android App Bundle

# ART/Dalvik 字节码文件
*.dex

# Java / Kotlin 编译后的字节码
*.class

# 构建输出目录（Eclipse / 旧版工具）
bin/
gen/
out/

# Gradle 缓存和构建目录
.gradle/
build/

# Kotlin 编译缓存（KMP 通用）
.kotlin/
.kotlin-js-store/   # Kotlin/JS 编译缓存

# NDK / CMake 构建输出
.cxx/
.externalNativeBuild/

# ProGuard 输出目录（Eclipse 时代遗留，极少使用）
proguard/

# ============================================================================
# 3. IDE 相关配置（Android Studio / IntelliJ）
#    （避免团队中 IDE 配置差异导致冲突）
# ============================================================================

*.iml                 # 模块文件
.idea/                # 项目配置目录（包含 workspace.xml 等全部）
local.properties      # 本地 SDK 路径（每台机器不同）

# ============================================================================
# 4. 敏感信息（安全关键，必须忽略）
# ============================================================================

*.jks                 # Java 密钥库（签名证书）
*.keystore            # Android 签名密钥文件
google-services.json  # Firebase / GMS 配置文件（含 API 密钥）

# ============================================================================
# 5. 特定工具相关（按项目实际使用情况保留）
# ============================================================================

